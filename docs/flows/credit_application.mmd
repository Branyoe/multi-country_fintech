flowchart TD

    %% ── Fase sincrónica (HTTP request) ─────────────────────────
    START(["POST /api/applications/ -- JWT"])

    AUTH{"¿JWT válido?"}
    E401["401 Unauthorized"]

    VAL_DOC["validate_document() -- regex por país"]
    DOC_OK{"¿Formato válido?"}
    E422["422 Documento inválido"]

    PERSIST["Persistir CreditApplication -- estado inicial"]
    BOOTSTRAP["update_status() bootstrap -- Celery task dispatched -- 201 inmediato"]
    R201(["201 Created"])

    START --> AUTH
    AUTH -- "No" --> E401
    AUTH -- "Sí" --> VAL_DOC
    VAL_DOC --> DOC_OK
    DOC_OK -- "No" --> E422
    DOC_OK -- "Sí" --> PERSIST
    PERSIST --> BOOTSTRAP --> R201

    %% ── Fase asíncrona (Celery pipeline) ────────────────────────
    T_DOC["validating_document_task -- solo MX"]
    T_BANK["fetching_bank_data_task -- persiste BankProviderData"]
    T_RULES["validate_country_rules_task -- persiste CountryValidation"]
    T_NOTIFY["notify_final_decision_task -- webhook saliente"]

    APPROVED(["approved"])
    REJECTED(["rejected"])
    TECH_ERR["technical_error -- retries agotados"]

    BOOTSTRAP -. "MX" .-> T_DOC
    BOOTSTRAP -. "CO" .-> T_BANK
    T_DOC -- "CURP válida" --> T_BANK
    T_DOC -- "CURP inválida" --> REJECTED
    T_DOC -- "error" --> TECH_ERR
    T_BANK -- "éxito" --> T_RULES
    T_BANK -- "error" --> TECH_ERR
    T_RULES -- "valid=true" --> APPROVED
    T_RULES -- "valid=false" --> REJECTED
    T_RULES -- "error" --> TECH_ERR
    APPROVED --> T_NOTIFY
    REJECTED --> T_NOTIFY

    style START fill:#D3D1C7,stroke:#5F5E5A,color:#2C2C2A
    style R201 fill:#C0DD97,stroke:#3B6D11,color:#173404
    style E401 fill:#F09595,stroke:#A32D2D,color:#501313
    style E422 fill:#F09595,stroke:#A32D2D,color:#501313
    style APPROVED fill:#C0DD97,stroke:#3B6D11,color:#173404
    style REJECTED fill:#F09595,stroke:#A32D2D,color:#501313
    style TECH_ERR fill:#FAC775,stroke:#854F0B,color:#412402
    style T_DOC fill:#CECBF6,stroke:#534AB7,color:#26215C
    style T_BANK fill:#CECBF6,stroke:#534AB7,color:#26215C
    style T_RULES fill:#CECBF6,stroke:#534AB7,color:#26215C
    style T_NOTIFY fill:#9FE1CB,stroke:#0F6E56,color:#04342C
    style PERSIST fill:#B5D4F4,stroke:#185FA5,color:#042C53
    style BOOTSTRAP fill:#B5D4F4,stroke:#185FA5,color:#042C53
