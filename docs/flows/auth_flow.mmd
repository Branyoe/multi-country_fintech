flowchart TD

    %% ── App bootstrap ──────────────────────────────────────────
    BOOT(["App carga — bootstrap()"])

    CHECK_RT{"¿refresh token en localStorage?"}

    REFRESH_BOOT["POST /api/auth/token/refresh/"]
    BOOT_OK["setTokens — Zustand + localStorage"]
    BOOT_FAIL["clearTokens — localStorage vacío"]

    READY(["App lista — RouterProvider mount"])

    BOOT --> CHECK_RT
    CHECK_RT -- "No" --> READY
    CHECK_RT -- "Sí" --> REFRESH_BOOT
    REFRESH_BOOT -- "200 OK" --> BOOT_OK --> READY
    REFRESH_BOOT -- "401" --> BOOT_FAIL --> READY

    %% ── Route loader guard ──────────────────────────────────────
    NAV(["Navegación a ruta protegida /"])

    LOADER{"requireAuth loader — ¿accessToken en Zustand?"}
    REDIRECT_LOGIN["redirect /login?next=/"]

    RENDER_HOME(["Renderiza HomePage — scaffold"])

    READY --> NAV
    NAV --> LOADER
    LOADER -- "No" --> REDIRECT_LOGIN
    LOADER -- "Sí" --> RENDER_HOME

    %% ── Signup ──────────────────────────────────────────────────
    SIGNUP_START(["POST /signup — Form method post"])

    SIGNUP_API["publicApi — POST /api/auth/signup/"]

    SIGNUP_OK["redirect /login?registered=1 — banner verde"]

    SIGNUP_ERR["return error — useActionData a UI"]
    E400_DUP["400 email ya existe"]
    E400_PASS["400 password inválido"]

    SIGNUP_START --> SIGNUP_API
    SIGNUP_API -- "201 Created" --> SIGNUP_OK --> REDIRECT_LOGIN
    SIGNUP_API -- "400" --> E400_DUP --> SIGNUP_ERR
    SIGNUP_API -- "400" --> E400_PASS --> SIGNUP_ERR

    %% ── Login ───────────────────────────────────────────────────
    LOGIN_START(["POST /login — Form method post"])

    LOGIN_BODY{"¿Email y password presentes?"}
    E_HTML5["No navega — HTML5 required"]

    LOGIN_API["publicApi — POST /api/auth/token/"]

    LOGIN_OK["setTokens — Zustand + localStorage — redirect /"]

    LOGIN_ERR["Credenciales inválidas — useActionData a UI"]

    E401["401 Unauthorized"]
    E_UNEXPECTED["Error inesperado"]

    REDIRECT_LOGIN --> LOGIN_START
    LOGIN_START --> LOGIN_BODY
    LOGIN_BODY -- "No" --> E_HTML5
    LOGIN_BODY -- "Sí" --> LOGIN_API
    LOGIN_API -- "200 OK" --> LOGIN_OK --> RENDER_HOME
    LOGIN_API -- "401" --> E401 --> LOGIN_ERR
    LOGIN_API -- "otro error" --> E_UNEXPECTED --> LOGIN_ERR

    %% ── Request a endpoint protegido ────────────────────────────
    REQ(["Request a endpoint protegido via api"])

    INJECT["request interceptor — Authorization Bearer access"]

    RES_OK(["Response exitosa"])

    IS_401{"¿401?"}
    HAS_RT{"¿refresh token en localStorage?"}

    DO_REFRESH["POST /api/auth/token/refresh/ con refresh guardado"]

    RETRY["setTokens nuevo access — reintentar request — vaciar cola"]

    CLEAR_REDIRECT["clearAuth — window.location /login"]

    RENDER_HOME --> REQ
    REQ --> INJECT --> IS_401
    IS_401 -- "No" --> RES_OK
    IS_401 -- "Sí" --> HAS_RT
    HAS_RT -- "No" --> CLEAR_REDIRECT
    HAS_RT -- "Sí" --> DO_REFRESH
    DO_REFRESH -- "200 OK" --> RETRY --> RES_OK
    DO_REFRESH -- "401 inválido" --> CLEAR_REDIRECT

    %% ── Logout ──────────────────────────────────────────────────
    LOGOUT(["Logout — clearAuth + navigate /login"])
    RENDER_HOME --> LOGOUT --> REDIRECT_LOGIN

    %% ── Styles ──────────────────────────────────────────────────
    style BOOT fill:#D3D1C7,stroke:#5F5E5A,color:#2C2C2A
    style READY fill:#D3D1C7,stroke:#5F5E5A,color:#2C2C2A
    style RENDER_HOME fill:#C0DD97,stroke:#3B6D11,color:#173404
    style RES_OK fill:#C0DD97,stroke:#3B6D11,color:#173404
    style SIGNUP_OK fill:#C0DD97,stroke:#3B6D11,color:#173404
    style LOGIN_OK fill:#C0DD97,stroke:#3B6D11,color:#173404
    style LOGIN_ERR fill:#F09595,stroke:#A32D2D,color:#501313
    style SIGNUP_ERR fill:#F09595,stroke:#A32D2D,color:#501313
    style E401 fill:#F09595,stroke:#A32D2D,color:#501313
    style E400_DUP fill:#F09595,stroke:#A32D2D,color:#501313
    style E400_PASS fill:#F09595,stroke:#A32D2D,color:#501313
    style E_UNEXPECTED fill:#F09595,stroke:#A32D2D,color:#501313
    style CLEAR_REDIRECT fill:#F09595,stroke:#A32D2D,color:#501313
    style E_HTML5 fill:#FAC775,stroke:#854F0B,color:#412402
    style BOOT_FAIL fill:#FAC775,stroke:#854F0B,color:#412402
    style DO_REFRESH fill:#CECBF6,stroke:#534AB7,color:#26215C
    style RETRY fill:#CECBF6,stroke:#534AB7,color:#26215C
    style REFRESH_BOOT fill:#CECBF6,stroke:#534AB7,color:#26215C
    style BOOT_OK fill:#CECBF6,stroke:#534AB7,color:#26215C
    style LOGIN_API fill:#9FE1CB,stroke:#0F6E56,color:#04342C
    style SIGNUP_API fill:#9FE1CB,stroke:#0F6E56,color:#04342C
    style INJECT fill:#9FE1CB,stroke:#0F6E56,color:#04342C
